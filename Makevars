# ------------------------------------------------------------------------------
# US Census API Key
# ------------------------------------------------------------------------------
API_KEY ?= $(USCENSUSAPIKEY)

# Fail if API_KEY is not set
ifeq ($(API_KEY),)
$(error API_KEY is empty.  Export USCENSUSAPIKEY in your shell or set API_KEY in the Makefile.)
endif

RSCRIPTVANILLA ?= Rscript --vanilla

